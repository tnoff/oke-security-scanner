# Normalize line endings on checkout / commit
* text=auto eol=lf

# Explicit text files
*.py        text diff=python
*.md        text
*.yaml      text
*.yml       text
*.toml      text
*.json      text
*.ini       text
*.cfg       text
*.sh        text eol=lf
Dockerfile  text
LICENSE     text
VERSION     text
CHANGELOG.md text merge=union

# Binary files (no diff/merge attempts)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.tar       binary
*.tar.gz    binary
*.tgz       binary
*.zip       binary
*.whl       binary

# Files excluded from `git archive` / source release tarballs
.gitattributes  export-ignore
.gitignore      export-ignore
.gitlab-ci.yml  export-ignore
.github/**      export-ignore
.dockerignore   export-ignore
tox.ini         export-ignore
renovate.json   export-ignore
tests/**        export-ignore
AGENTS.md       export-ignore
DEVELOPMENT.md  export-ignore
